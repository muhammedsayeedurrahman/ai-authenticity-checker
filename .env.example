# ─────────────────────────────────────────────────────────────
# ProofyX Environment Variables
# Copy this file to .env and fill in your actual keys.
# Multiple keys per service enable automatic fallback.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL recommended for production)
# If not set, falls back to local SQLite (dev mode).
DATABASE_URL=postgresql+asyncpg://proofyx:proofyx_dev@localhost:5432/proofyx

# Supabase Authentication (backend)
# If not set, auth is disabled and all requests pass through (dev mode).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ProofyX REST API Authentication (API key mode)
# If set, all /api/v1/analyze/* endpoints require X-API-Key header.
# If no keys are set and no Supabase config, the API runs unauthenticated (dev mode).
PROOFYX_API_KEY_1=
PROOFYX_API_KEY_2=

# Google Cloud Vision (future integration)
GOOGLE_VISION_KEY_1=
GOOGLE_VISION_KEY_2=

# HuggingFace Hub Token
HF_TOKEN_1=

# Twilio (future: SMS/voice verification)
TWILIO_SID_1=
TWILIO_TOKEN_1=
TWILIO_SID_2=
TWILIO_TOKEN_2=

# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables (prefix with VITE_ for Vite)
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
