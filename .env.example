# ─────────────────────────────────────────────────────────────
# ProofyX Environment Variables
# Copy this file to .env and fill in your actual keys.
# Multiple keys per service enable automatic fallback.
# ─────────────────────────────────────────────────────────────

# ProofyX REST API Authentication
# If set, all /api/v1/analyze/* endpoints require X-API-Key header.
# If no keys are set, the API runs unauthenticated (dev mode).
PROOFYX_API_KEY_1=
PROOFYX_API_KEY_2=

# Google Cloud Vision (future integration)
GOOGLE_VISION_KEY_1=
GOOGLE_VISION_KEY_2=

# HuggingFace Hub Token
HF_TOKEN_1=

# Twilio (future: SMS/voice verification)
TWILIO_SID_1=
TWILIO_TOKEN_1=
TWILIO_SID_2=
TWILIO_TOKEN_2=
