{
  "models_dir": "models",
  "device": "auto",
  "threshold": 0.5,
  "idle_unload_seconds": 600,

  "vit": {
    "type": "huggingface",
    "model_id": "prithivMLmods/Deep-Fake-Detector-v2-Model",
    "weight": 0.40,
    "enabled": true,
    "description": "ViT deepfake detector (HuggingFace)"
  },
  "texture": {
    "type": "local",
    "class": "EfficientNetTexture",
    "path": "efficient.pth",
    "weight": 0.20,
    "enabled": true,
    "description": "EfficientNet-B4 texture analysis"
  },
  "frequency": {
    "type": "local",
    "class": "FrequencyCNN",
    "path": "frequency.pth",
    "weight": 0.10,
    "enabled": true,
    "description": "Frequency-domain CNN (FFT features)"
  },
  "face": {
    "type": "local",
    "class": "FaceDeepfakeModel",
    "path": "image_face_model.pth",
    "weight": 0.10,
    "enabled": true,
    "requires_face": true,
    "description": "ResNet50 face deepfake detector"
  },
  "dino": {
    "type": "local",
    "class": "DINOv2AuthModel",
    "path": "dinov2_auth_model.pth",
    "weight": 0.05,
    "enabled": true,
    "description": "DINOv2 fine-tuned authentication"
  },
  "efficientnet": {
    "type": "local",
    "class": "EfficientNetAuthModel",
    "path": "efficientnet_auth_model.pth",
    "weight": 0.15,
    "enabled": true,
    "description": "EfficientNetV2-S authentication"
  },
  "fusion": {
    "type": "local",
    "class": "FusionMLP",
    "path": "fusion_mlp.pth",
    "weight": null,
    "enabled": true,
    "n_inputs": 7,
    "description": "Learned fusion with temperature calibration (7 models)"
  },
  "corefakenet": {
    "type": "local",
    "class": "CorefakeNet",
    "path": "corefakenet.pth",
    "weight": 1.0,
    "enabled": true,
    "fast_mode": true,
    "description": "Unified hybrid CNN (5 heads, attention fusion)"
  },
  "clip": {
    "type": "huggingface",
    "model_id": "yermandy/deepfake-detection",
    "weight": 0.15,
    "enabled": true,
    "description": "CLIP ViT-L/14 deepfake detector (LN-tuning, TorchScript)"
  },

  "ensemble_weights": {
    "_note": "forensic is a heuristic (not a trained model) — given minimal weight as supplementary signal",
    "default": {
      "vit": 0.35,
      "clip": 0.15,
      "texture": 0.20,
      "frequency": 0.10,
      "face": 0.10,
      "dino": 0.05,
      "forensic": 0.05
    },
    "face_boosted": {
      "vit": 0.30,
      "clip": 0.15,
      "texture": 0.15,
      "frequency": 0.10,
      "face": 0.20,
      "dino": 0.05,
      "forensic": 0.05
    }
  },

  "calibration": {
    "_calibration_status": "uncalibrated",
    "_note": "Temperatures set to 1.0 (identity) — proper Platt scaling requires a held-out validation set. Do NOT use arbitrary values. To calibrate: collect model outputs on a balanced held-out set (e.g., FF++, Celeb-DF), fit temperature via NLL minimization per model, then update per_model_temperatures.",
    "temperature": 1.0,
    "high_confidence_override": 0.60,
    "per_model_temperatures": {
      "vit": 1.0,
      "clip": 1.0,
      "texture": 1.0,
      "frequency": 1.0,
      "face": 1.0,
      "dino": 1.0,
      "efficientnet": 1.0,
      "forensic": 1.0
    }
  },

  "audio": {
    "type": "local",
    "path": "audio_deepfake_model.pth",
    "enabled": true,
    "description": "Audio deepfake CNN"
  },
  "wav2vec2_audio": {
    "type": "huggingface",
    "model_id": "garystafford/wav2vec2-deepfake-voice-detector",
    "enabled": true,
    "description": "Wav2Vec2-XLSR-300M fine-tuned for audio deepfake detection"
  },

  "api_keys": {
    "_comment": "API key pools are loaded from .env — this section documents supported services",
    "services": [
      "PROOFYX_API_KEY",
      "GOOGLE_VISION_KEY",
      "HF_TOKEN",
      "TWILIO_SID",
      "TWILIO_TOKEN"
    ],
    "auth_required_routes": ["/api/v1/analyze/*"],
    "public_routes": ["/api/v1/health", "/api/v1/models/status"]
  }
}
